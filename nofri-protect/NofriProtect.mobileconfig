  <key>PayloadDisplayName</key>
  <string>Nofri Protect</string>
  <key>PayloadDescription</key>
  <string>Routes all DNS on this device through a family-safe filter (Cloudflare for Families) that blocks adult and malicious websites — in every app and browser, including Private/Incognito. Part of Nofri Protect.</string>
  <key>PayloadIdentifier</key>
  <string>app.nofri.protect</string>
