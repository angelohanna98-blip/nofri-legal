      <key>PayloadUUID</key>
      <string>5E2B7C10-0001-4A30-9F00-A1B2C3D4E5F6</string>
      <key>PayloadDisplayName</key>
      <string>Nofri Protect — Family-Safe DNS</string>
      <key>DNSSettings</key>
      <dict>
        <key>DNSProtocol</key>
        <string>HTTPS</string>
        <key>ServerURL</key>
